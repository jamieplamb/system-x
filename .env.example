APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=system_x
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Local dev uses Herd's managed Reverb service (enable it in Herd > Services > Reverb).
# It is a shared service with fixed, well-known credentials, TLS-terminated by Herd's
# nginx at reverb.herd.test. In production set real credentials and your own Reverb host.
REVERB_APP_ID=1001
REVERB_APP_KEY=laravel-herd
REVERB_APP_SECRET=secret
REVERB_HOST=reverb.herd.test
REVERB_PORT=443
REVERB_SCHEME=https
# Point at your dev CA bundle so PHP cURL trusts the self-signed Reverb cert when
# broadcasting (PHP cURL does not consult the macOS keychain). For Herd this is the Valet
# CA, e.g. "$HOME/Library/Application Support/Herd/config/valet/CA/LaravelValetCASelfSigned.pem".
# Leave unset in production (defaults to the system CA bundle).
REVERB_TLS_VERIFY=
# Origins allowed for the WebSocket handshake when SELF-HOSTING Reverb. Defaults to APP_URL's
# host, so it usually needs no setting. Set it (comma-separated) if your page is served from a
# different host than APP_URL, or to allow several. A wrong/missing value is a SILENT 403 on the
# WS upgrade -- the desktop renders but nothing updates live.
# REVERB_ALLOWED_ORIGINS=

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
